{
  "id": "1629e2f7-febd-40dc-8d94-01e7d9728067",
  "name": "Finished Escrow",
  "states": [
    "Idle",
    "Funded",
    "Completed",
    "Disputed",
    "Refunded"
  ],
  "initialState": "Idle",
  "transitions": [
    {
      "id": "t1-fund",
      "name": "fund",
      "from": "Idle",
      "to": "Funded",
      "payable": true,
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == payer"
            },
            "operator": "AND",
            "errorMessage": "Only the payer can fund the escrow"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.value == amount"
            },
            "operator": "AND",
            "errorMessage": "Incorrect funding amount"
          }
        ]
      },
      "statements": [],
      "emitEvent": "Funded",
      "emitEventArgs": [
        "msg.sender",
        "msg.value"
      ]
    },
    {
      "id": "t2-complete",
      "name": "complete",
      "from": "Funded",
      "to": "Completed",
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == payer"
            },
            "operator": "AND",
            "errorMessage": "Only the payer can confirm completion"
          }
        ]
      },
      "statements": [
        "payable(provider).transfer(amount);"
      ],
      "emitEvent": "Completed",
      "emitEventArgs": [
        "provider",
        "amount"
      ]
    },
    {
      "id": "t3-dispute",
      "name": "dispute",
      "from": "Funded",
      "to": "Disputed",
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == payer || msg.sender == provider"
            },
            "operator": "AND",
            "errorMessage": "Only payer or provider can raise a dispute"
          }
        ]
      },
      "statements": [],
      "emitEvent": "Disputed",
      "emitEventArgs": [
        "msg.sender"
      ]
    },
    {
      "id": "t4-resolve-provider",
      "name": "resolveForProvider",
      "from": "Disputed",
      "to": "Completed",
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == arbiter"
            },
            "operator": "AND",
            "errorMessage": "Only the arbiter can resolve disputes"
          }
        ]
      },
      "statements": [
        "payable(provider).transfer(amount);"
      ],
      "emitEvent": "Resolved",
      "emitEventArgs": [
        "provider",
        "amount"
      ]
    },
    {
      "id": "t5-resolve-payer",
      "name": "resolveForPayer",
      "from": "Disputed",
      "to": "Refunded",
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == arbiter"
            },
            "operator": "AND",
            "errorMessage": "Only the arbiter can resolve disputes"
          }
        ]
      },
      "statements": [
        "payable(payer).transfer(amount);"
      ],
      "emitEvent": "Resolved",
      "emitEventArgs": [
        "payer",
        "amount"
      ]
    },
    {
      "id": "t6-refund",
      "name": "refund",
      "from": "Funded",
      "to": "Refunded",
      "inputs": [],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.sender == payer"
            },
            "operator": "AND",
            "errorMessage": "Only the payer can request a refund"
          },
          {
            "guard": {
              "type": "deadline",
              "timestamp": "deadline"
            },
            "operator": "AND",
            "errorMessage": "Refund deadline has not passed yet"
          }
        ]
      },
      "statements": [
        "payable(payer).transfer(amount);"
      ],
      "emitEvent": "Refunded",
      "emitEventArgs": [
        "payer",
        "amount"
      ]
    }
  ],
