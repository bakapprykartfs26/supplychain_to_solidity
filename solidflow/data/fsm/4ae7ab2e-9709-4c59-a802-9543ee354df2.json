{
  "name": "Lottery v2",
  "states": [
    "Buy",
    "Reveal"
  ],
  "initialState": "Buy",
  "transitions": [
    {
      "id": "41e0c9be-7ca0-428d-af19-9ef4cd62cda8",
      "name": "buyTicket",
      "from": "Buy",
      "to": "Buy",
      "payable": true,
      "inputs": [
        {
          "type": "bytes32",
          "name": "secret"
        }
      ],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.value == ticketPrice"
            },
            "operator": "AND",
            "errorMessage": "Incorrect ticket price"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "secret != bytes32(0)"
            },
            "operator": "AND",
            "errorMessage": "Invalid secret"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "secrets[msg.sender] == bytes32(0)"
            },
            "operator": "AND",
            "errorMessage": "Only one ticket per player is allowed"
          }
        ]
      },
      "statements": [
        "secrets[msg.sender] = secret;",
        "jackpot += msg.value;"
      ],
      "emitEvent": "TicketSold",
      "emitEventArgs": [
        "msg.sender",
        "jackpot"
      ]
    },
    {
      "id": "2790223e-9342-4611-94a7-097c1ca3c0b4",
      "name": "switchToReveal",
      "from": "Buy",
      "to": "Reveal",
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "block.timestamp > deadlineBuy"
            },
            "operator": "AND",
            "errorMessage": "Buy stage deadline has not passed yet"
          }
        ]
      }
    },
    {
      "id": "63bc83cc-150e-4628-94c9-cf4fb6b859b8",
      "name": "revealSecret",
      "from": "Reveal",
      "to": "Reveal",
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "secrets[msg.sender] != bytes32(0)"
            },
            "operator": "AND",
            "errorMessage": "No secret to reveal"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "keccak256(abi.encode(secretNumber)) == secrets[msg.sender]"
            },
            "operator": "AND",
            "errorMessage": "Secret does not match commitment"
          }
        ]
      },
      "statements": [
        "secrets[msg.sender] = bytes32(0);",
        "players.push(msg.sender);",
        "randomNumber = uint(keccak256(abi.encodePacked(randomNumber, secretNumber)));"
      ],
      "inputs": [
        {
          "type": "uint256",
          "name": "secretNumber"
        }
      ]
    },
    {
      "id": "514823e1-b3a4-4dd8-b0db-80dcf5334829",
      "name": "evaluate",
      "from": "Reveal",
      "to": "Buy",
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "block.timestamp > deadlineReveal"
            },
            "operator": "AND",
            "errorMessage": "Reveal stage deadline has not passed yet"
          }
        ]
      },
      "statements": [
        {
          "type": "if",
          "condition": "players.length != 0",
          "body": [
            "uint numberOfPlayers = players.length;",
            "uint winnerIndex = randomNumber % numberOfPlayers;",
            "address winner = players[winnerIndex];",
            "winners[winner] += jackpot;",
            "emit WinnerSelected(winner, jackpot);",
            "jackpot = 0;"
          ],
          "elseIfs": []
        },
        "delete players;",
        "deadlineBuy = block.timestamp + buyStageDuration;",
        "deadlineReveal = deadlineBuy + revealStageDuration;",
        "randomNumber = 0;"
      ]
    },
    {
      "id": "b60a1075-36de-44cb-8bad-443d5131beb9",
      "name": "bCollect",
      "from": "Buy",
      "to": "Buy",
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "winners[msg.sender] > 0"
            },
            "operator": "AND",
            "errorMessage": "Nothing to collect"
          }
        ]
      },
      "statements": [
        "uint amount = winners[msg.sender];",
        "winners[msg.sender] = 0;",
        "payable(msg.sender).transfer(amount);"
      ]
    },
    {
      "id": "7d3a216f-126f-4c7c-863f-ebe53c3bfd96",
      "name": "rCollect",
      "from": "Reveal",
      "to": "Reveal",
      "statements": [
        "uint amount = winners[msg.sender];",
        "winners[msg.sender] = 0;",
        "payable(msg.sender).transfer(amount);"
      ],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "winners[msg.sender] > 0"
            },
            "operator": "AND",
            "errorMessage": "Nothing to collect"
          }
        ]
      }
    }
  ],
  "id": "4ae7ab2e-9709-4c59-a802-9543ee354df2",
  "createdAt": "2026-04-29T12:10:04.038Z",
  "updatedAt": "2026-04-29T12:42:28.037Z",
  "variables": [
    {
      "name": "players",
      "type": "address",
      "visibility": "public",
      "isArray": true,
      "dimensions": [
        {
          "size": ""
        }
      ]
    },
    {
      "name": "buyStageDuration",
      "type": "uint256",
      "visibility": "public"
    },
    {
      "name": "revealStageDuration",
      "type": "uint256",
      "visibility": "public"
    },
    {
      "name": "deadlineBuy",
      "type": "uint256",
      "visibility": "public",
      "initialValue": "block.timestamp + buyStageDuration"
    },
    {
      "name": "deadlineReveal",
      "type": "uint256",
      "visibility": "public",
      "initialValue": "deadlineBuy + revealStageDuration"
    },
    {
      "name": "ticketPrice",
      "type": "uint256",
      "visibility": "public"
    },
    {
      "name": "jackpot",
      "type": "uint256",
      "visibility": "public"
    },
    {
      "name": "randomNumber",
      "type": "uint256",
      "visibility": "public"
    }
  ],
  "mappings": [
    {
      "name": "secrets",
      "keyType": "address",
      "valueType": "bytes32",
      "visibility": "public"
    },
    {
      "name": "winners",
      "keyType": "address",
      "valueType": "uint256",
      "visibility": "public"
    }
  ],
  "events": [
    {
      "name": "TicketSold",
      "params": [
        {
          "name": "buyer",
          "type": "address",
          "indexed": true
        },
        {
          "name": "updatedJackpot",
          "type": "uint256"
        }
      ]
    },
    {
      "name": "WinnerSelected",
      "params": [
        {
          "name": "winner",
          "type": "address",
          "indexed": true
        },
        {
          "name": "payout",
          "type": "uint256"
        }
      ]
    }
  ],
  "plugins": {
    "event": true
  },
  "constructorConfig": {
    "includedVariables": [
      "buyStageDuration",
      "revealStageDuration",
      "ticketPrice"
    ],
    "includedArrays": [],
    "includedStructs": [],
    "guardConfig": {
      "guards": [
        {
          "guard": {
            "type": "input-validation",
            "expression": "_ticketPrice > 0"
          },
          "operator": "AND",
          "errorMessage": "Ticket price must be positive"
        }
      ]
    }
  }
}