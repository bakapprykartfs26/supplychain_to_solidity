{
  "name": "Lottery",
  "states": [
    "Buy Stage",
    "Reveal Stage"
  ],
  "initialState": "Buy Stage",
  "transitions": [
    {
      "id": "fd357a15-7af4-4c8f-8734-bb134a5c9b71",
      "name": "buyTicket",
      "from": "Buy Stage",
      "to": "Buy Stage",
      "payable": true,
      "inputs": [
        {
          "type": "bytes32",
          "name": "secret"
        }
      ],
      "emitEvent": "TicketSold",
      "emitEventArgs": [
        "msg.sender",
        "jackpot"
      ],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "msg.value == ticketPrice"
            },
            "operator": "AND",
            "errorMessage": "asdf"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "secret != bytes32(0)"
            },
            "operator": "AND"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "1==1"
            },
            "operator": "AND"
          }
        ]
      },
      "statements": [
        "/// secrets[msg.sender] = secret;",
        "jackpot += msg.value;"
      ]
    },
    {
      "id": "2816716c-4711-4e60-9fb8-3eba0a1e425f",
      "name": "switchToReveal",
      "from": "Buy Stage",
      "to": "Reveal Stage",
      "emitEvent": "StageChange",
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "block.timestamp > deadlineBuy"
            },
            "operator": "AND"
          }
        ]
      }
    },
    {
      "id": "9f19ff38-d28d-4cdf-8246-ee6effd1126d",
      "name": "revealSecret",
      "from": "Reveal Stage",
      "to": "Reveal Stage",
      "inputs": [
        {
          "type": "uint256",
          "name": "secretNumber"
        }
      ],
      "guardConfig": {
        "guards": [
          {
            "guard": {
              "type": "input-validation",
              "expression": "1 == 1"
            },
            "operator": "AND"
          },
          {
            "guard": {
              "type": "input-validation",
              "expression": "keccak256(abi.encode(secretNumber)) == bytes32(0)"
            },
            "operator": "AND"
          }
        ]
      }
    },
    {
      "id": "335468b6-c807-4eca-bbd5-ac3a58385204",
      "name": "evaluate",
      "from": "Reveal Stage",
      "to": "Buy Stage",
      "emitEvent": "WinnerSelected",
      "emitEventArgs": [
        "players[0]",
        "jackpot"
      ]
    },
    {
      "id": "2bffc5c4-af3d-4762-8e04-5c794ec0c6f0",
      "name": "collect",
      "from": "Reveal Stage",
      "to": "Reveal Stage"
    },
    {
      "id": "ddf19262-bc6e-419d-ad83-4a9db9706e47",
      "name": "collect2",
      "from": "Buy Stage",
      "to": "Buy Stage"
    }
  ],
  "id": "59ac2058-3f20-4bb9-93b2-95921c1699f3",
